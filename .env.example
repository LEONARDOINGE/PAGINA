# ===========================================
# CONFIGURACION FOTOTEC - VARIABLES DE ENTORNO
# ===========================================
# Copia este archivo como .env y completa los valores

# Puerto del servidor (default: 3000)
PORT=3000

# Path de la base de datos SQLite (opcional)
# DATABASE_PATH=./data/database.db

# Configuracion SMTP para envio de emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=fototecventass@gmail.com
SMTP_PASS=tu_contrasena_de_aplicacion

# ===========================================
# NOTA: Para Gmail necesitas una contrasena de aplicacion
# 1. Ve a tu cuenta de Google -> Seguridad
# 2. Verificacion en 2 pasos -> Contrasenas de aplicacion
# 3. Genera una nueva contrasena para "Correo"
# ===========================================
