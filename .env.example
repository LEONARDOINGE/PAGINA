# ===========================================
# CONFIGURACION FOTOTEC - VARIABLES DE ENTORNO
# ===========================================
# Copia este archivo como .env y completa los valores

# Puerto del servidor (default: 3000)
PORT=3000

# Turso SQLite en la nube (gratis)
# Crea cuenta en https://turso.tech y crea una base de datos
# Copia la URL de conexion de tu dashboard
TURSO_DATABASE_URL=libsql://tu-db.turso.io
TURSO_AUTH_TOKEN=your_token_here

# ===========================================
# NOTA: Para Resend, crea cuenta en https://resend.com
# Genera una API key y pegala aqui
# ===========================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
