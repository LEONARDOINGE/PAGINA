---
import Layout from '../../../layouts/Main.astro';
---

<Layout title="Auditoria" activeModule="erp" activePage="Auditoria">
<div class="space-y-6">
  <div><h2 class="text-xl font-bold text-gray-900">Log de Auditoria</h2><p class="text-sm text-gray-500">ERP &bull; Registro de cambios en el sistema</p></div>

  <div class="card overflow-hidden p-0">
    <div class="p-4 border-b border-gray-100 flex items-center gap-3">
      <div class="search-bar flex-1">
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <input type="text" class="search-input" placeholder="Buscar por entidad o accion..." id="audit-search" oninput="searchAudit(this.value)" />
      </div>
      <select class="input w-auto" id="audit-entity" onchange="loadAudit()">
        <option value="">Todas las entidades</option>
        <option value="client">Clientes</option>
        <option value="product">Productos</option>
        <option value="invoice">Facturas</option>
        <option value="employee">Empleados</option>
        <option value="purchase_order">Ordenes Compra</option>
      </select>
    </div>
    <table class="w-full text-sm">
      <thead class="table-header">
        <tr><th class="px-4 py-3 text-left">Fecha/Hora</th><th class="px-4 py-3 text-left">Usuario</th><th class="px-4 py-3 text-left">Accion</th><th class="px-4 py-3 text-left">Entidad</th><th class="px-4 py-3 text-left">ID</th><th class="px-4 py-3 text-left">IP</th></tr>
      </thead>
      <tbody id="audit-table"><tr><td colspan="6" class="px-4 py-8 text-center text-gray-400">Cargando...</td></tr></tbody>
    </table>
  </div>
</div>

<script>
let auditTimer;
async function loadAudit(entity = '') {
  try {
    const data = await window.gql(`query { auditLogs(entityType: "${entity}", limit: 50) { id action entityType entityId ipAddress created_at user { name } } }`);
    const logs = data.auditLogs || [];
    const badge = { create: 'badge-success', update: 'badge-info', delete: 'badge-danger', login: 'badge-purple', receive: 'badge-success', stock_adjust: 'badge-warning', convert: 'badge-purple' };

    document.getElementById('audit-table').innerHTML = logs.length ? logs.map(l => `<tr class="table-row">
      <td class="px-4 py-3 text-gray-500 text-xs">${new Date(l.created_at).toLocaleString('es-MX')}</td>
      <td class="px-4 py-3">${l.user?.name || 'Sistema'}</td>
      <td class="px-4 py-3"><span class="${badge[l.action] || 'badge-info'}">${l.action}</span></td>
      <td class="px-4 py-3 text-gray-500">${l.entityType}</td>
      <td class="px-4 py-3 font-mono text-xs">#${l.entityId}</td>
      <td class="px-4 py-3 text-gray-400 text-xs">${l.ipAddress || '-'}</td>
    </tr>`).join('') : '<tr><td colspan="6" class="px-4 py-8 text-center text-gray-400">Sin registros</td></tr>';
  } catch (err) { console.error(err); }
}

window.searchAudit = (q) => { clearTimeout(auditTimer); auditTimer = setTimeout(() => loadAudit(document.getElementById('audit-entity').value), 300); };

loadAudit();
</script>
</Layout>
