---
import Layout from '../../../layouts/Main.astro';
---

<Layout title="Notas" activeModule="crm" activePage="Notas">
<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div><h2 class="text-xl font-bold text-gray-900">Notas de Clientes</h2><p class="text-sm text-gray-500">CRM &bull; Notas, pinned y privadas</p></div>
    <div class="flex gap-2">
      <select class="input w-auto" id="note-entity" onchange="loadNotes()">
        <option value="">Todas</option><option value="client">Clientes</option>
        <option value="lead">Leads</option><option value="invoice">Facturas</option>
      </select>
    </div>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="notes-grid">
    <div class="col-span-3 card-sm text-center text-gray-400 py-8">Cargando...</div>
  </div>
</div>

<script>
async function loadNotes() {
  const entity = document.getElementById('note-entity')?.value || '';
  try {
    const data = await window.gql(`query { notes${entity ? `(entityType: "${entity}")` : ''} { id content pinned private created_at user { name } entityType entityId } }`);
    const notes = data.notes || [];
    document.getElementById('notes-grid').innerHTML = notes.length ? notes.map(n => `<div class="card ${n.pinned ? 'border-l-4 border-yellow-500' : ''}">
      <div class="flex items-center justify-between mb-2">
        <div class="flex items-center gap-2">
          ${n.pinned ? '<span class="text-yellow-500 text-xs">\u2605 Fijada</span>' : ''}
          ${n.private ? '<span class="text-red-400 text-xs">\uD83D\uDD12 Privada</span>' : ''}
          <span class="badge-info text-xs">${n.entityType}</span>
        </div>
        <span class="text-xs text-gray-400">${new Date(n.created_at).toLocaleDateString('es-MX')}</span>
      </div>
      <p class="text-sm text-gray-700 whitespace-pre-wrap">${n.content}</p>
      <div class="mt-3 text-xs text-gray-400">Por: ${n.user?.name || 'Sistema'}</div>
    </div>`).join('') : '<div class="col-span-3 card-sm text-center text-gray-400 py-8">Sin notas</div>';
  } catch (err) { console.error(err); }
}
loadNotes();
</script>
</Layout>
