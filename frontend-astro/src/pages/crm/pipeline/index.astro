---
import Layout from '../../../layouts/Main.astro';
---

<Layout title="Pipeline de Ventas" activeModule="crm" activePage="Pipeline">
<div class="space-y-6">

  <div class="flex items-center justify-between">
    <div>
      <h2 class="text-xl font-bold text-gray-900">Pipeline de Ventas</h2>
      <p class="text-sm text-gray-500">CRM &bull; Seguimiento de oportunidades</p>
    </div>
    <button onclick="showCreateModal()" class="btn-primary flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Nuevo Lead
    </button>
  </div>

  <!-- Pipeline Funnel -->
  <div class="grid grid-cols-4 gap-4">
    <div class="card-sm border-l-4 border-blue-500" onclick="filterByStage('nuevo')" style="cursor:pointer">
      <div class="text-3xl font-bold text-blue-600" id="stage-nuevo">--</div>
      <div class="text-sm font-medium text-gray-700">Nuevas Interesadas</div>
      <div class="text-xs text-gray-400 mt-1">Leads sin contactar</div>
    </div>
    <div class="card-sm border-l-4 border-yellow-500" onclick="filterByStage('propuesta')" style="cursor:pointer">
      <div class="text-3xl font-bold text-yellow-600" id="stage-propuesta">--</div>
      <div class="text-sm font-medium text-gray-700">Cotizadas</div>
      <div class="text-xs text-gray-400 mt-1">Con propuesta enviada</div>
    </div>
    <div class="card-sm border-l-4 border-orange-500" onclick="filterByStage('calificado')" style="cursor:pointer">
      <div class="text-3xl font-bold text-orange-600" id="stage-calificado">--</div>
      <div class="text-sm font-medium text-gray-700">Apartadas</div>
      <div class="text-xs text-gray-400 mt-1">En negociacion</div>
    </div>
    <div class="card-sm border-l-4 border-green-500" onclick="filterByStage('ganado')" style="cursor:pointer">
      <div class="text-3xl font-bold text-green-600" id="stage-ganado">--</div>
      <div class="text-sm font-medium text-gray-700">Entregadas</div>
      <div class="text-xs text-gray-400 mt-1">Cerradas exitosamente</div>
    </div>
  </div>

  <!-- Leads Table -->
  <div class="card overflow-hidden p-0">
    <div class="p-4 border-b border-gray-100 flex items-center gap-3 flex-wrap">
      <div class="flex gap-2">
        <button class="tab-btn-active" onclick="filterByStage('')" id="tab-all">Todos</button>
        <button class="tab-btn" onclick="filterByStage('nuevo')" id="tab-nuevo">Nuevas</button>
        <button class="tab-btn" onclick="filterByStage('propuesta')" id="tab-propuesta">Cotizadas</button>
        <button class="tab-btn" onclick="filterByStage('negociacion')" id="tab-negociacion">Negociacion</button>
      </div>
      <div class="ml-auto search-bar">
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <input type="text" class="search-input" placeholder="Buscar leads..." id="lead-search" oninput="searchLeads(this.value)" />
      </div>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="table-header">
          <tr>
            <th class="px-4 py-3 text-left">Lead</th>
            <th class="px-4 py-3 text-left">Cliente</th>
            <th class="px-4 py-3 text-left">Etapa</th>
            <th class="px-4 py-3 text-left">Score</th>
            <th class="px-4 py-3 text-left">Presupuesto</th>
            <th class="px-4 py-3 text-left">Asignado</th>
            <th class="px-4 py-3 text-left">Fecha</th>
            <th class="px-4 py-3 text-left">Acciones</th>
          </tr>
        </thead>
        <tbody id="leads-table" class="divide-y divide-gray-50">
          <tr><td colspan="8" class="px-4 py-8 text-center text-gray-400">Cargando...</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div id="lead-modal" class="hidden">
  <div class="modal-overlay" onclick="closeLeadModal()">
    <div class="modal-content" onclick="event.stopPropagation()">
      <div class="p-6 border-b border-gray-100 flex items-center justify-between">
        <h3 class="text-lg font-semibold">Nuevo Lead</h3>
        <button onclick="closeLeadModal()" class="p-1 rounded hover:bg-gray-100">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <form id="lead-form" class="p-6 space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div><label class="label">Cliente *</label><select id="l-client" class="input" required><option value="">Seleccionar cliente...</option></select></div>
          <div><label class="label">Etapa</label><select id="l-stage" class="input"><option value="nuevo">Nuevo</option><option value="contactado">Contactado</option><option value="calificado">Calificado</option><option value="propuesta">Propuesta</option><option value="negociacion">Negociacion</option></select></div>
          <div><label class="label">Score (0-100)</label><input type="number" id="l-score" class="input" min="0" max="100" value="50" /></div>
          <div><label class="label">Presupuesto</label><input type="number" id="l-budget" class="input" placeholder="0.00" step="0.01" /></div>
          <div><label class="label">Nivel de Interes</label><select id="l-interest" class="input"><option value="">Seleccionar...</option><option value="alto">Alto</option><option value="medio">Medio</option><option value="bajo">Bajo</option></select></div>
          <div><label class="label">Timeline</label><select id="l-timeline" class="input"><option value="">Seleccionar...</option><option value="inmediato">Inmediato</option><option value="1_mes">1 mes</option><option value="3_meses">3 meses</option><option value="6_meses">6 meses</option></select></div>
        </div>
        <div><label class="label">Notas</label><textarea id="l-notes" class="input" rows="3"></textarea></div>
        <div class="flex justify-end gap-3 pt-4 border-t border-gray-100">
          <button type="button" onclick="closeLeadModal()" class="btn-secondary">Cancelar</button>
          <button type="submit" class="btn-primary">Crear Lead</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
let currentStage = '';

async function loadLeads(stage = '') {
  currentStage = stage;
  document.querySelectorAll('.tab-btn, .tab-btn-active').forEach(b => {
    b.classList.remove('tab-btn-active');
    b.classList.add('tab-btn');
  });
  if (stage) {
    const tab = document.getElementById('tab-' + stage);
    if (tab) { tab.classList.add('tab-btn-active'); tab.classList.remove('tab-btn'); }
  } else {
    document.getElementById('tab-all')?.classList.add('tab-btn-active');
    document.getElementById('tab-all')?.classList.remove('tab-btn');
  }

  try {
    const data = await window.gql(`query { leads${stage ? `(stage: ${stage})` : ''} { id stage score budget source interestLevel notes created_at client { id name email } assignedTo { name } } }`);
    const leads = data.leads || [];

    ['nuevo', 'propuesta', 'calificado', 'ganado'].forEach(s => {
      document.getElementById('stage-' + s).textContent = leads.filter(l => l.stage === s).length;
    });

    const tbody = document.getElementById('leads-table');
    if (!leads.length) { tbody.innerHTML = '<tr><td colspan="8" class="px-4 py-8 text-center text-gray-400">Sin leads en esta etapa</td></tr>'; return; }

    tbody.innerHTML = leads.map(l => {
      const stageColor = { nuevo: 'badge-purple', contactado: 'badge-info', calificado: 'badge-info', propuesta: 'badge-warning', negociacion: 'badge-warning', ganado: 'badge-success', perdido: 'badge-danger' }[l.stage] || 'badge-info';
      const scoreColor = l.score >= 70 ? 'text-green-600' : l.score >= 40 ? 'text-yellow-600' : 'text-red-600';
      return `<tr class="table-row">
        <td class="px-4 py-3 font-medium text-gray-900">${l.client?.name || 'N/A'}</td>
        <td class="px-4 py-3 text-gray-600 text-xs">${l.client?.email || ''}</td>
        <td class="px-4 py-3"><span class="${stageColor}">${l.stage}</span></td>
        <td class="px-4 py-3"><span class="font-bold ${scoreColor}">${l.score || 0}</span></td>
        <td class="px-4 py-3 text-gray-900 font-medium">${l.budget ? '$' + Number(l.budget).toLocaleString('es-MX') : '-'}</td>
        <td class="px-4 py-3 text-gray-600 text-xs">${l.assignedTo?.name || 'Sin asignar'}</td>
        <td class="px-4 py-3 text-gray-400 text-xs">${new Date(l.created_at).toLocaleDateString('es-MX')}</td>
        <td class="px-4 py-3">
          <div class="flex gap-1">
            <button onclick="convertLead('${l.id}')" class="btn-sm btn-success" title="Convertir a Cliente">Convertir</button>
            <button onclick="editLead('${l.id}')" class="p-1.5 rounded hover:bg-gray-100 text-gray-500" title="Editar"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg></button>
          </div>
        </td>
      </tr>`;
    }).join('');

  } catch (err) { console.error(err); }
}

window.filterByStage = (stage) => loadLeads(stage);
window.searchLeads = (q) => loadLeads(currentStage);

window.showCreateModal = () => document.getElementById('lead-modal').classList.remove('hidden');
window.closeLeadModal = () => document.getElementById('lead-modal').classList.add('hidden');

window.convertLead = async (id) => {
  if (!confirm('Convertir este lead a cliente?')) return;
  try {
    await window.gql(`mutation { convertLead(id: "${id}") { id name } }`);
    alert('Lead convertido exitosamente');
    loadLeads(currentStage);
  } catch (err) { alert('Error: ' + err.message); }
};

document.getElementById('lead-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  try {
    await window.gql(`mutation {
      createLead(input: {
        clientId: "${document.getElementById('l-client').value}",
        stage: "${document.getElementById('l-stage').value}",
        score: ${document.getElementById('l-score').value || 0},
        budget: ${document.getElementById('l-budget').value || 0},
        interestLevel: "${document.getElementById('l-interest').value}",
        timeline: "${document.getElementById('l-timeline').value}",
        notes: "${document.getElementById('l-notes').value}"
      }) { id }
    }`);
    closeLeadModal();
    loadLeads(currentStage);
  } catch (err) { alert('Error: ' + err.message); }
});

loadLeads();
</script>
</Layout>
