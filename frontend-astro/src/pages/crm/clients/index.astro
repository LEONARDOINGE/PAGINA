---
import Layout from '../../../layouts/Main.astro';
---

<Layout title="Clientes" activeModule="crm" activePage="Clientes">
<div class="space-y-6">

  <div class="flex items-center justify-between">
    <div>
      <h2 class="text-xl font-bold text-gray-900">Gestion de Clientes</h2>
      <p class="text-sm text-gray-500">CRM &bull; Modulo de Clientes</p>
    </div>
    <button onclick="showCreateModal()" class="inline-flex items-center gap-2 px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors text-sm font-medium">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Nuevo Cliente
    </button>
  </div>

  <!-- Filters -->
  <div class="bg-white rounded-xl border border-gray-200 p-4 flex flex-wrap items-center gap-4">
    <div class="flex-1 min-w-64 relative">
      <svg class="w-4 h-4 text-gray-400 absolute left-3 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      <input type="text" placeholder="Buscar por nombre, email o empresa..." id="search-input" oninput="debounceSearch(this.value)" class="w-full pl-10 pr-4 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
    </div>
    <select id="segment-filter" onchange="loadClients(1)" class="px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white">
      <option value="">Todos los segmentos</option>
      <option value="personal">Personal</option>
      <option value="corporativo">Corporativo</option>
      <option value="pequena">Pequena</option>
      <option value="media">Media</option>
      <option value="fotografo">Fotografo</option>
    </select>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
      <div class="text-2xl font-bold text-primary-600" id="stat-total">0</div>
      <div class="text-xs text-gray-500 mt-1">Total Clientes</div>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
      <div class="text-2xl font-bold text-green-600" id="stat-active">0</div>
      <div class="text-xs text-gray-500 mt-1">Activos</div>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
      <div class="text-2xl font-bold text-purple-600" id="stat-corp">0</div>
      <div class="text-xs text-gray-500 mt-1">Corporativos</div>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
      <div class="text-2xl font-bold text-amber-500" id="stat-ltv">$0</div>
      <div class="text-xs text-gray-500 mt-1">Valor Total LTV</div>
    </div>
  </div>

  <!-- Table -->
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Cliente</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Contacto</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Empresa</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Segmento</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Lifetime Value</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Estado</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Acciones</th>
          </tr>
        </thead>
        <tbody id="clients-table" class="divide-y divide-gray-100">
          <tr>
            <td colspan="7" class="px-4 py-12 text-center text-gray-400">
              <svg class="w-8 h-8 mx-auto mb-2 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              Cargando clientes...
            </td>
          </tr>
        </tbody>
      </table>
    </div>
    <div class="px-4 py-3 border-t border-gray-200 flex items-center justify-between bg-gray-50">
      <div class="text-sm text-gray-500" id="pagination-info">Mostrando 0 de 0 clientes</div>
      <div class="flex gap-1" id="pagination-buttons"></div>
    </div>
  </div>
</div>

<!-- Create/Edit Modal -->
<div id="client-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
  <div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0">
    <div class="fixed inset-0 transition-opacity bg-black bg-opacity-50" onclick="closeModal()"></div>
    <div class="inline-block align-bottom bg-white rounded-2xl text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-2xl sm:w-full">
      <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
        <h3 class="text-lg font-semibold text-gray-900" id="modal-title">Nuevo Cliente</h3>
        <button onclick="closeModal()" class="p-1 rounded-lg hover:bg-gray-100 text-gray-400 hover:text-gray-600 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <form id="client-form" class="p-6 space-y-4">
        <input type="hidden" id="client-id" />
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Nombre *</label>
            <input type="text" id="c-name" required class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
            <input type="email" id="c-email" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Telefono</label>
            <input type="text" id="c-phone" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Empresa</label>
            <input type="text" id="c-company" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">RFC</label>
            <input type="text" id="c-rfc" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Segmento</label>
            <select id="c-segment" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white">
              <option value="personal">Personal</option>
              <option value="corporativo">Corporativo</option>
              <option value="pequena">Pequena</option>
              <option value="media">Media</option>
              <option value="fotografo">Fotografo</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Ciudad</label>
            <input type="text" id="c-city" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Estado</label>
            <input type="text" id="c-state" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Pais</label>
            <input type="text" id="c-country" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Activo</label>
            <select id="c-active" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white">
              <option value="true">Si</option>
              <option value="false">No</option>
            </select>
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Direccion</label>
          <textarea id="c-address" rows="2" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500"></textarea>
        </div>
        <div class="flex justify-end gap-3 pt-4 border-t border-gray-200">
          <button type="button" onclick="closeModal()" class="px-4 py-2 border border-gray-200 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">Cancelar</button>
          <button type="submit" class="px-4 py-2 bg-primary-600 text-white rounded-lg text-sm font-medium hover:bg-primary-700 transition-colors">Guardar</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Delete Confirmation Modal -->
<div id="delete-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
  <div class="flex items-center justify-center min-h-screen px-4">
    <div class="fixed inset-0 transition-opacity bg-black bg-opacity-50" onclick="closeDeleteModal()"></div>
    <div class="inline-block align-bottom bg-white rounded-xl text-left overflow-hidden shadow-xl transform transition-all sm:align-middle sm:max-w-md sm:w-full">
      <div class="p-6 text-center">
        <div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-red-100 mb-4">
          <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Eliminar Cliente</h3>
        <p class="text-sm text-gray-500 mb-6">Esta seguro que desea eliminar este cliente? Esta accion no se puede deshacer.</p>
        <div class="flex gap-3 justify-center">
          <button onclick="closeDeleteModal()" class="px-4 py-2 border border-gray-200 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">Cancelar</button>
          <button onclick="confirmDelete()" class="px-4 py-2 bg-red-600 text-white rounded-lg text-sm font-medium hover:bg-red-700 transition-colors">Eliminar</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Toast Notification -->
<div id="toast" class="hidden fixed bottom-4 right-4 px-4 py-3 rounded-lg shadow-lg text-sm font-medium z-50 transition-all transform translate-y-full opacity-0"></div>

<script is:inline>
(function() {
  var currentPage = 1;
  var searchTimeout;
  var deleteTargetId = null;
  var perPage = 50;

  function showToast(message, type) {
    var toast = document.getElementById('toast');
    toast.textContent = message;
    toast.classList.remove('hidden', 'translate-y-full', 'opacity-0');
    if (type === 'success') {
      toast.classList.add('bg-green-500', 'text-white');
      toast.classList.remove('bg-red-500', 'text-white');
    } else {
      toast.classList.add('bg-red-500', 'text-white');
      toast.classList.remove('bg-green-500', 'text-white');
    }
    setTimeout(function() {
      toast.classList.add('translate-y-full', 'opacity-0');
      setTimeout(function() { toast.classList.add('hidden'); }, 300);
    }, 3000);
  }

  window.loadClients = async function(page) {
    if (page === undefined) page = currentPage;
    currentPage = page;
    var searchInput = document.getElementById('search-input');
    var segmentFilter = document.getElementById('segment-filter');
    var search = searchInput ? searchInput.value : '';
    var segment = segmentFilter ? segmentFilter.value : '';

    var tbody = document.getElementById('clients-table');
    tbody.innerHTML = '<tr><td colspan="7" class="px-4 py-12 text-center text-gray-400"><svg class="w-8 h-8 mx-auto mb-2 text-gray-300 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>Cargando...</td></tr>';

    try {
      var query = 'query { clients(search: "' + encodeURIComponent(search) + '", segment: "' + encodeURIComponent(segment) + '", page: ' + page + ', perPage: ' + perPage + ') { data { id name email phone company segment lifetime_value active created_at } total } }';
      var data = await window.graphql(query);
      var clients = data.clients.data;
      var total = data.clients.total;

      if (!clients || clients.length === 0) {
        tbody.innerHTML = '<tr><td colspan="7" class="px-4 py-12 text-center text-gray-400"><svg class="w-12 h-12 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>No se encontraron clientes</td></tr>';
        document.getElementById('pagination-info').textContent = 'Mostrando 0 de 0 clientes';
        document.getElementById('pagination-buttons').innerHTML = '';
        updateStats(0, clients);
        return;
      }

      tbody.innerHTML = clients.map(function(c) {
        var initial = c.name ? c.name.charAt(0).toUpperCase() : '?';
        var segmentClass = 'bg-gray-100 text-gray-700';
        if (c.segment === 'corporativo') segmentClass = 'bg-purple-100 text-purple-700';
        else if (c.segment === 'fotografo') segmentClass = 'bg-blue-100 text-blue-700';
        else if (c.segment === 'pequena') segmentClass = 'bg-green-100 text-green-700';
        else if (c.segment === 'media') segmentClass = 'bg-amber-100 text-amber-700';
        else if (c.segment === 'personal') segmentClass = 'bg-pink-100 text-pink-700';

        var statusClass = c.active ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500';
        var statusText = c.active ? 'Activo' : 'Inactivo';

        var ltv = c.lifetime_value || 0;
        var ltvFormatted = '$' + Number(ltv).toLocaleString('es-MX');

        return '<tr class="hover:bg-gray-50 transition-colors">' +
          '<td class="px-4 py-3">' +
            '<div class="flex items-center gap-3">' +
              '<div class="w-10 h-10 rounded-full bg-gradient-to-br from-primary-400 to-primary-600 flex items-center justify-center text-white font-bold text-sm">' + initial + '</div>' +
              '<div>' +
                '<div class="font-medium text-gray-900">' + (c.name || '-') + '</div>' +
                '<div class="text-xs text-gray-400">ID: ' + c.id + '</div>' +
              '</div>' +
            '</div>' +
          '</td>' +
          '<td class="px-4 py-3">' +
            '<div class="text-gray-900">' + (c.email || '-') + '</div>' +
            '<div class="text-xs text-gray-500">' + (c.phone || '-') + '</div>' +
          '</td>' +
          '<td class="px-4 py-3 text-gray-600">' + (c.company || '-') + '</td>' +
          '<td class="px-4 py-3"><span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ' + segmentClass + '">' + (c.segment || 'personal') + '</span></td>' +
          '<td class="px-4 py-3 font-semibold text-gray-900">' + ltvFormatted + '</td>' +
          '<td class="px-4 py-3"><span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ' + statusClass + '">' + statusText + '</span></td>' +
          '<td class="px-4 py-3">' +
            '<div class="flex items-center gap-1">' +
              '<button onclick="viewClient(\'' + c.id + '\')" class="p-1.5 rounded-lg hover:bg-gray-100 text-gray-400 hover:text-gray-600 transition-colors" title="Ver">' +
                '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>' +
              '</button>' +
              '<button onclick="editClient(\'' + c.id + '\')" class="p-1.5 rounded-lg hover:bg-gray-100 text-gray-400 hover:text-gray-600 transition-colors" title="Editar">' +
                '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>' +
              '</button>' +
              '<button onclick="deleteClient(\'' + c.id + '\')" class="p-1.5 rounded-lg hover:bg-red-50 text-gray-400 hover:text-red-500 transition-colors" title="Eliminar">' +
                '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>' +
              '</button>' +
            '</div>' +
          '</td>' +
        '</tr>';
      }).join('');

      document.getElementById('pagination-info').textContent = 'Mostrando ' + clients.length + ' de ' + total + ' clientes';
      renderPagination(total, page);
      updateStats(total, clients);

    } catch (err) {
      console.error('Error loading clients:', err);
      tbody.innerHTML = '<tr><td colspan="7" class="px-4 py-12 text-center text-red-400">Error al cargar clientes: ' + (err.message || 'Unknown error') + '</td></tr>';
      showToast('Error al cargar clientes', 'error');
    }
  };

  function updateStats(total, clients) {
    document.getElementById('stat-total').textContent = total;
    var activeCount = clients ? clients.filter(function(c) { return c.active; }).length : 0;
    document.getElementById('stat-active').textContent = activeCount;
    var corpCount = clients ? clients.filter(function(c) { return c.segment === 'corporativo'; }).length : 0;
    document.getElementById('stat-corp').textContent = corpCount;
    var totalLtv = clients ? clients.reduce(function(sum, c) { return sum + (Number(c.lifetime_value) || 0); }, 0) : 0;
    document.getElementById('stat-ltv').textContent = '$' + Number(totalLtv).toLocaleString('es-MX');
  }

  function renderPagination(total, current) {
    var totalPages = Math.ceil(total / perPage);
    var btns = document.getElementById('pagination-buttons');
    btns.innerHTML = '';

    if (totalPages <= 1) return;

    var maxButtons = 5;
    var startPage = Math.max(1, current - Math.floor(maxButtons / 2));
    var endPage = Math.min(totalPages, startPage + maxButtons - 1);

    if (endPage - startPage < maxButtons - 1) {
      startPage = Math.max(1, endPage - maxButtons + 1);
    }

    if (current > 1) {
      btns.innerHTML += '<button onclick="loadClients(' + (current - 1) + ')" class="px-3 py-1.5 border border-gray-200 rounded-lg text-sm hover:bg-gray-50 transition-colors mr-1">Anterior</button>';
    }

    for (var i = startPage; i <= endPage; i++) {
      var isActive = i === current;
      btns.innerHTML += '<button onclick="loadClients(' + i + ')" class="px-3 py-1.5 border rounded-lg text-sm transition-colors ' + (isActive ? 'bg-primary-600 text-white border-primary-600' : 'border-gray-200 hover:bg-gray-50') + '">' + i + '</button>';
    }

    if (current < totalPages) {
      btns.innerHTML += '<button onclick="loadClients(' + (current + 1) + ')" class="px-3 py-1.5 border border-gray-200 rounded-lg text-sm hover:bg-gray-50 transition-colors ml-1">Siguiente</button>';
    }
  }

  window.debounceSearch = function(val) {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(function() { loadClients(1); }, 400);
  };

  window.showCreateModal = function() {
    document.getElementById('modal-title').textContent = 'Nuevo Cliente';
    document.getElementById('client-form').reset();
    document.getElementById('client-id').value = '';
    document.getElementById('c-active').value = 'true';
    document.getElementById('client-modal').classList.remove('hidden');
    document.getElementById('c-name').focus();
  };

  window.editClient = async function(id) {
    try {
      var query = 'query { client(id: "' + id + '") { id name email phone company segment lifetime_value active city state country address rfc created_at } }';
      var data = await window.graphql(query);
      var c = data.client;

      document.getElementById('client-id').value = c.id || '';
      document.getElementById('c-name').value = c.name || '';
      document.getElementById('c-email').value = c.email || '';
      document.getElementById('c-phone').value = c.phone || '';
      document.getElementById('c-company').value = c.company || '';
      document.getElementById('c-rfc').value = c.rfc || '';
      document.getElementById('c-segment').value = c.segment || 'personal';
      document.getElementById('c-city').value = c.city || '';
      document.getElementById('c-state').value = c.state || '';
      document.getElementById('c-country').value = c.country || '';
      document.getElementById('c-address').value = c.address || '';
      document.getElementById('c-active').value = c.active ? 'true' : 'false';

      document.getElementById('modal-title').textContent = 'Editar Cliente';
      document.getElementById('client-modal').classList.remove('hidden');
      document.getElementById('c-name').focus();
    } catch (err) {
      console.error('Error loading client:', err);
      showToast('Error al cargar datos del cliente', 'error');
    }
  };

  window.viewClient = function(id) {
    window.location.href = '/crm/clients/' + id;
  };

  window.closeModal = function() {
    document.getElementById('client-modal').classList.add('hidden');
  };

  window.deleteClient = function(id) {
    deleteTargetId = id;
    document.getElementById('delete-modal').classList.remove('hidden');
  };

  window.closeDeleteModal = function() {
    document.getElementById('delete-modal').classList.add('hidden');
    deleteTargetId = null;
  };

  window.confirmDelete = async function() {
    if (!deleteTargetId) return;

    try {
      var mutation = 'mutation { deleteClient(id: "' + deleteTargetId + '") }';
      await window.graphql(mutation);
      showToast('Cliente eliminado exitosamente', 'success');
      closeDeleteModal();
      loadClients(currentPage);
    } catch (err) {
      console.error('Error deleting client:', err);
      showToast('Error al eliminar cliente', 'error');
    }
  };

  document.getElementById('client-form').addEventListener('submit', async function(e) {
    e.preventDefault();

    var id = document.getElementById('client-id').value;
    var input = {
      name: document.getElementById('c-name').value,
      email: document.getElementById('c-email').value,
      phone: document.getElementById('c-phone').value,
      company: document.getElementById('c-company').value,
      rfc: document.getElementById('c-rfc').value,
      segment: document.getElementById('c-segment').value,
      city: document.getElementById('c-city').value,
      state: document.getElementById('c-state').value,
      country: document.getElementById('c-country').value,
      address: document.getElementById('c-address').value,
      active: document.getElementById('c-active').value === 'true'
    };

    if (!input.name) {
      showToast('El nombre es requerido', 'error');
      return;
    }

    try {
      if (id) {
        var updateMutation = 'mutation { updateClient(id: "' + id + '", input: {name:"' + input.name + '",email:"' + (input.email || '') + '",phone:"' + (input.phone || '') + '",company:"' + (input.company || '') + '",segment:"' + input.segment + '",city:"' + (input.city || '') + '",state:"' + (input.state || '') + '",country:"' + (input.country || '') + '",address:"' + (input.address || '') + '",rfc:"' + (input.rfc || '') + '",active:' + input.active + '}) { id } }';
        await window.graphql(updateMutation);
        showToast('Cliente actualizado exitosamente', 'success');
      } else {
        var createMutation = 'mutation { createClient(input: {name:"' + input.name + '",email:"' + (input.email || '') + '",phone:"' + (input.phone || '') + '",company:"' + (input.company || '') + '",segment:"' + input.segment + '",city:"' + (input.city || '') + '",state:"' + (input.state || '') + '",country:"' + (input.country || '') + '",address:"' + (input.address || '') + '",rfc:"' + (input.rfc || '') + '"}) { id } }';
        await window.graphql(createMutation);
        showToast('Cliente creado exitosamente', 'success');
      }
      closeModal();
      loadClients(currentPage);
    } catch (err) {
      console.error('Error saving client:', err);
      showToast('Error al guardar cliente: ' + (err.message || 'Unknown error'), 'error');
    }
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      closeModal();
      closeDeleteModal();
    }
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() { loadClients(1); });
  } else {
    loadClients(1);
  }
})();
</script>
</Layout>
