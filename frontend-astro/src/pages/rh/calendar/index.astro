---
import Layout from '../../../layouts/Main.astro';
---

<Layout title="Calendario RH" activeModule="rh" activePage="Calendario">
<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div><h2 class="text-xl font-bold text-gray-900">Calendario de RRHH</h2><p class="text-sm text-gray-500">RRHH &bull; Eventos y ausencias</p></div>
    <div class="flex gap-2">
      <button onclick="prevMonth()" class="btn-outline btn-sm">&#8592;</button>
      <span class="font-semibold self-center" id="cal-month"></span>
      <button onclick="nextMonth()" class="btn-outline btn-sm">&#8594;</button>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2">
      <div class="card p-0 overflow-hidden">
        <div class="grid grid-cols-7 border-b border-gray-200">
          <div class="text-center py-2 text-xs font-semibold text-gray-500">Lun</div>
          <div class="text-center py-2 text-xs font-semibold text-gray-500">Mar</div>
          <div class="text-center py-2 text-xs font-semibold text-gray-500">Mie</div>
          <div class="text-center py-2 text-xs font-semibold text-gray-500">Jue</div>
          <div class="text-center py-2 text-xs font-semibold text-gray-500">Vie</div>
          <div class="text-center py-2 text-xs font-semibold text-purple-500">Sab</div>
          <div class="text-center py-2 text-xs font-semibold text-red-400">Dom</div>
        </div>
        <div class="grid grid-cols-7" id="calendar-grid"></div>
      </div>
    </div>

    <div class="space-y-4">
      <div class="card">
        <h3 class="font-semibold text-gray-900 mb-3">Eventos del Mes</h3>
        <div class="space-y-2" id="month-events"></div>
      </div>
      <div class="card">
        <h3 class="font-semibold text-gray-900 mb-3">Leyenda</h3>
        <div class="space-y-2 text-sm">
          <div class="flex items-center gap-2"><div class="w-3 h-3 rounded bg-blue-500"></div><span>Dia laboral</span></div>
          <div class="flex items-center gap-2"><div class="w-3 h-3 rounded bg-yellow-500"></div><span>Vacaciones</span></div>
          <div class="flex items-center gap-2"><div class="w-3 h-3 rounded bg-red-500"></div><span>Festivo MX</span></div>
          <div class="flex items-center gap-2"><div class="w-3 h-3 rounded bg-purple-500"></div><span>Cumpleanos</span></div>
          <div class="flex items-center gap-2"><div class="w-3 h-3 rounded bg-orange-500"></div><span>Incapacidades</span></div>
        </div>
      </div>
      <div class="card">
        <h3 class="font-semibold text-gray-900 mb-3">Proximos Eventos</h3>
        <div class="space-y-2" id="upcoming-events"></div>
      </div>
    </div>
  </div>
</div>

<script>
let currentDate = new Date();

const HOLIDAYS_MX = [
  { date: '2026-01-01', name: 'Anio Nuevo' },
  { date: '2026-02-03', name: 'Dia de la Constitucion' },
  { date: '2026-03-16', name: 'Natalicio de Benito Juarez' },
  { date: '2026-04-02', name: 'Jueves Santo' },
  { date: '2026-04-03', name: 'Viernes Santo' },
  { date: '2026-05-01', name: 'Dia del Trabajo' },
  { date: '2026-09-16', name: 'Dia de la Independencia' },
  { date: '2026-11-16', name: 'Dia de la Revolucion' },
  { date: '2026-12-25', name: 'Navidad' },
];

async function loadCalendar() {
  const year = currentDate.getFullYear();
  const month = currentDate.getMonth();
  document.getElementById('cal-month').textContent = currentDate.toLocaleDateString('es-MX', { month: 'long', year: 'numeric' });

  try {
    const data = await window.gql(`query { employees(page: 1, perPage: 100) { data { id name birthDate hireDate department { color } } } leaves(status: aprobada) { id type startDate endDate days employee { name } } appointments { id title date time } }`);
    const emps = data.employees?.data || [];
    const leaves = data.leaves || [];
    const appts = data.appointments || [];

    const grid = document.getElementById('calendar-grid');
    const firstDay = new Date(year, month, 1).getDay();
    const daysInMonth = new Date(year, month + 1, 0).getDate();
    const startDay = firstDay === 0 ? 6 : firstDay - 1;

    let html = '';
    for (let i = 0; i < startDay; i++) html += '<div class="min-h-24 border-r border-b border-gray-100 bg-gray-50"></div>';

    for (let day = 1; day <= daysInMonth; day++) {
      const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
      const isWeekend = new Date(year, month, day).getDay() === 0 || new Date(year, month, day).getDay() === 6;
      const holiday = HOLIDAYS_MX.find(h => h.date === dateStr);
      const birthdays = emps.filter(e => e.birthDate && e.birthDate.split('T')[0].slice(5) === `${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`);
      const dayLeaves = leaves.filter(l => dateStr >= l.startDate && dateStr <= l.endDate);
      const dayAppts = appts.filter(a => a.date === dateStr);

      let bg = 'bg-white hover:bg-gray-50';
      let dots = '';

      if (holiday) { bg = 'bg-red-50'; dots += '<div class="w-1.5 h-1.5 rounded-full bg-red-500 absolute top-1 right-1"></div>'; }
      else if (isWeekend) { bg = 'bg-gray-50'; }
      else if (dayLeaves.length) { bg = 'bg-yellow-50'; dots += '<div class="w-1.5 h-1.5 rounded-full bg-yellow-500 absolute top-1 right-1"></div>'; }
      if (birthdays.length) { dots += '<div class="w-1.5 h-1.5 rounded-full bg-purple-500 absolute bottom-1 right-1"></div>'; }
      if (dayAppts.length) { dots += '<div class="w-1.5 h-1.5 rounded-full bg-blue-500 absolute bottom-1 left-1"></div>'; }

      html += `<div class="min-h-24 border-r border-b border-gray-100 p-1 relative ${bg}">
        <span class="text-xs font-semibold ${isWeekend ? 'text-gray-400' : 'text-gray-700'} ${holiday ? 'text-red-600' : ''}">${day}</span>
        ${dots}
        ${holiday ? `<div class="text-xs text-red-600 mt-1 truncate">${holiday.name}</div>` : ''}
        ${birthdays.slice(0, 2).map(e => `<div class="text-xs bg-purple-100 text-purple-700 rounded px-1 mt-1 truncate">${e.name.split(' ')[0]} \uD83C\uDF89</div>`).join('')}
        ${dayLeaves.slice(0, 2).map(l => `<div class="text-xs bg-yellow-100 text-yellow-700 rounded px-1 mt-1 truncate">${l.employee?.name?.split(' ')[0]} - ${l.type}</div>`).join('')}
        ${dayAppts.slice(0, 2).map(a => `<div class="text-xs bg-blue-100 text-blue-700 rounded px-1 mt-1 truncate">${a.time} ${a.title}</div>`).join('')}
      </div>`;
    }
    grid.innerHTML = html;

    // Upcoming events
    const upcoming = [...birthdays.map(e => ({ type: 'Cumpleanos', name: e.name, date: e.birthDate, color: 'purple' })), ...dayLeaves.map(l => ({ type: l.type, name: l.employee?.name, date: l.startDate, color: 'yellow' }))];
    document.getElementById('upcoming-events').innerHTML = upcoming.slice(0, 5).map(e => `<div class="flex items-center gap-2 p-2 rounded-lg bg-${e.color}-50"><span class="text-xs font-medium text-${e.color}-700">${e.name} - ${e.type}</span></div>`).join('') || '<p class="text-sm text-gray-400">Sin eventos proximos</p>';

  } catch (err) { console.error(err); }
}

window.prevMonth = () => { currentDate.setMonth(currentDate.getMonth() - 1); loadCalendar(); };
window.nextMonth = () => { currentDate.setMonth(currentDate.getMonth() + 1); loadCalendar(); };

loadCalendar();
</script>
</Layout>
