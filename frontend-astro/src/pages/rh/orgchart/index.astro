---
import Layout from '../../../layouts/Main.astro';
---

<Layout title="Organigrama" activeModule="rh" activePage="Organigrama">
<div class="space-y-6">
  <div><h2 class="text-xl font-bold text-gray-900">Organigrama</h2><p class="text-sm text-gray-500">RRHH &bull; Estructura organizacional</p></div>
  <div class="card overflow-x-auto" id="org-chart">
    <div class="text-center text-gray-400 py-8">Cargando organigrama...</div>
  </div>
</div>

<script>
async function loadOrgChart() {
  try {
    const data = await window.gql(`query { departments { id name color manager { name position { name } } employees { id name position { name } } positions { id name level } } }`);
    const depts = data.departments || [];
    const el = document.getElementById('org-chart');

    el.innerHTML = `
      <div class="flex flex-col items-center gap-4 p-4">
        <div class="px-6 py-3 bg-primary-600 text-white rounded-xl font-bold text-center shadow-lg">
          <div class="text-lg">Direccion General</div>
          <div class="text-xs opacity-80">FotoTec Studio</div>
        </div>
        <div class="flex gap-4 flex-wrap justify-center">
          ${depts.map(d => `
            <div class="w-56">
              <div class="rounded-t-lg px-4 py-2 text-white font-bold text-sm text-center" style="background:${d.color}">
                ${d.name}
              </div>
              <div class="border-2 border-t-0 rounded-b-lg p-3 space-y-2">
                ${d.manager ? `<div class="bg-primary-50 rounded-lg p-2 text-center">
                  <div class="font-semibold text-xs text-primary-700">${d.manager.name}</div>
                  <div class="text-xs text-gray-500">${d.manager.position?.name || 'Manager'}</div>
                </div>` : ''}
                ${(d.employees || []).slice(0, 3).map(e => `<div class="text-xs text-center py-1 border-b border-gray-100">${e.name}<br><span class="text-gray-400">${e.position?.name || ''}</span></div>`).join('')}
                ${(d.employees || []).length > 3 ? `<div class="text-xs text-center text-gray-400">+${(d.employees || []).length - 3} mas</div>` : ''}
              </div>
            </div>
          `).join('')}
        </div>
      </div>
    `;
  } catch (err) { console.error(err); }
}
loadOrgChart();
</script>
</Layout>
