---
interface Props {
  title?: string;
}

const { title = 'FotoTec ERP' } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | FotoTec</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js" is:inline></script>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', system-ui, sans-serif; }
    .min-h-screen { min-height: 100vh; }
    .flex { display: flex; }
    .items-center { align-items: center; }
    .justify-center { justify-content: center; }
    .bg-gradient-to-br { background: linear-gradient(135deg, #7c3aed 0%, #6d28d9 50%, #4c1d95 100%); }
    .max-w-md { max-width: 28rem; }
    .w-full { width: 100%; }
    .p-8 { padding: 2rem; }
    .rounded-2xl { border-radius: 1rem; }
    .bg-white\\/10 { background: rgba(255,255,255,0.1); }
    .backdrop-blur { backdrop-filter: blur(12px); }
    .border-white\\/20 { border: 1px solid rgba(255,255,255,0.2); }
    .text-white { color: white; }
    .text-purple-200 { color: #ddd6fe; }
    .text-purple-300\\/60 { color: rgba(196,181,253,0.6); }
    .text-xs { font-size: 0.75rem; }
    .text-sm { font-size: 0.875rem; }
    .text-center { text-align: center; }
    .mb-8 { margin-bottom: 2rem; }
    .mt-2 { margin-top: 0.5rem; }
    .mt-6 { margin-top: 1.5rem; }
    .space-y-4 > * + * { margin-top: 1rem; }
    .label { display: block; font-size: 0.75rem; font-weight: 500; color: #ddd6fe; margin-bottom: 0.25rem; }
    .w-full { width: 100%; }
    .px-4 { padding-left: 1rem; padding-right: 1rem; }
    .py-3 { padding-top: 0.75rem; padding-bottom: 0.75rem; }
    .rounded-xl { border-radius: 0.75rem; }
    .bg-white\\/20 { background: rgba(255,255,255,0.2); }
    .border-white\\/30 { border: 1px solid rgba(255,255,255,0.3); }
    .text-white\\/20 { color: rgba(255,255,255,0.2); }
    .placeholder-purple-200\\/60::placeholder { color: rgba(221,214,254,0.6); }
    .focus\\:outline-none { outline: none; }
    .focus\\:ring-2 { box-shadow: 0 0 0 3px rgba(255,255,255,0.3); }
    .hover\\:bg-purple-50:hover { background: #faf5ff; }
    .transition-all { transition: all 0.2s; }
    .bg-white { background: white; }
    .text-primary-700 { color: #6d28d9; }
    .font-bold { font-weight: 700; }
    .hover\\:text-primary-700:hover { color: #5b21b6; }
    .flex { display: flex; }
    .items-center { align-items: center; }
    .justify-center { justify-content: center; }
    .gap-2 { gap: 0.5rem; }
    .py-12 { padding-top: 3rem; padding-bottom: 3rem; }
    .pt-6 { padding-top: 1.5rem; }
    .border-t { border-top: 1px solid rgba(255,255,255,0.2); }
    .grid { display: grid; }
    .grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .gap-2 { gap: 0.5rem; }
    .rounded-lg { border-radius: 0.5rem; }
    .p-2 { padding: 0.5rem; }
    .font-semibold { font-weight: 600; }
    .hidden { display: none; }
    .block { display: block; }
    .text-red-200 { color: #fecaca; }
    .text-sm { font-size: 0.875rem; }
    .animate-pulse { animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
    .btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.75rem 1.5rem; border-radius: 0.75rem; font-weight: 700; cursor: pointer; transition: all 0.2s; border: none; }
    .btn:disabled { opacity: 0.6; cursor: not-allowed; }
  </style>
</head>
<body class="min-h-screen flex items-center justify-center bg-gradient-to-br from-primary-600 via-primary-700 to-purple-900">
  <slot />
</body>
</html>
