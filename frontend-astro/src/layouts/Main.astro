---
interface Props {
  title?: string;
  activeModule?: string;
  activePage?: string;
}

const { title = 'FotoTec ERP', activeModule = '', activePage = '' } = Astro.props;

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000/graphql';

const modules = [
  { id: 'erp', label: 'ERP', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6', color: 'purple' },
  { id: 'crm', label: 'CRM', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z', color: 'blue' },
  { id: 'scm', label: 'SCM', icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4', color: 'green' },
  { id: 'rh', label: 'RRHH', icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z', color: 'red' },
];
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | FotoTec</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js" is:inline></script>
</head>
<body class="min-h-screen bg-gray-50 font-sans">
  <div class="flex h-screen overflow-hidden">

    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <div class="p-4 border-b border-gray-200">
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-lg bg-primary-600 flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <div>
            <div class="font-bold text-gray-900">FotoTec</div>
            <div class="text-xs text-gray-500">ERP Management</div>
          </div>
        </div>
      </div>

      <nav class="p-3 space-y-1">
        <div class="px-3 py-2 text-xs font-semibold text-gray-400 uppercase tracking-wider">Modulos</div>

        {modules.map(m => (
          <div data-module={m.id}>
            <div class={`nav-item ${activeModule === m.id ? 'nav-item-active' : ''} mb-1`}
                 onclick={`toggleModule('${m.id}')`}>
              <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={m.icon}/>
              </svg>
              <span>{m.label}</span>
              <svg class="w-4 h-4 ml-auto transform transition-transform" id={`arrow-${m.id}`}
                   fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </div>
            <div class="ml-4 space-y-0.5 hidden" id={`submenu-${m.id}`}>
              {m.id === 'erp' && <>
                <a href="/dashboard" class="nav-item text-xs py-1.5">Panel Principal</a>
                <a href="/erp/reports" class="nav-item text-xs py-1.5">Reportes</a>
                <a href="/erp/audit" class="nav-item text-xs py-1.5">Auditoria</a>
                <a href="/erp/settings" class="nav-item text-xs py-1.5">Configuracion</a>
              </>}
              {m.id === 'crm' && <>
                <a href="/crm/clients" class="nav-item text-xs py-1.5">Clientes</a>
                <a href="/crm/pipeline" class="nav-item text-xs py-1.5">Pipeline</a>
                <a href="/crm/quotes" class="nav-item text-xs py-1.5">Cotizaciones</a>
                <a href="/crm/invoices" class="nav-item text-xs py-1.5">Facturas</a>
                <a href="/crm/appointments" class="nav-item text-xs py-1.5">Citas</a>
                <a href="/crm/tickets" class="nav-item text-xs py-1.5">Tickets</a>
                <a href="/crm/campaigns" class="nav-item text-xs py-1.5">Campanas</a>
                <a href="/crm/surveys" class="nav-item text-xs py-1.5">Encuestas</a>
              </>}
              {m.id === 'scm' && <>
                <a href="/scm/products" class="nav-item text-xs py-1.5">Productos</a>
                <a href="/scm/inventory" class="nav-item text-xs py-1.5">Inventario</a>
                <a href="/scm/warehouses" class="nav-item text-xs py-1.5">Almacenes</a>
                <a href="/scm/suppliers" class="nav-item text-xs py-1.5">Proveedores</a>
                <a href="/scm/purchase-orders" class="nav-item text-xs py-1.5">Orden Compra</a>
                <a href="/scm/movements" class="nav-item text-xs py-1.5">Movimientos</a>
              </>}
              {m.id === 'rh' && <>
                <a href="/rh/employees" class="nav-item text-xs py-1.5">Empleados</a>
                <a href="/rh/departments" class="nav-item text-xs py-1.5">Departamentos</a>
                <a href="/rh/attendance" class="nav-item text-xs py-1.5">Asistencia</a>
                <a href="/rh/leaves" class="nav-item text-xs py-1.5">Permisos</a>
                <a href="/rh/trainings" class="nav-item text-xs py-1.5">Capacitaciones</a>
                <a href="/rh/reviews" class="nav-item text-xs py-1.5">Evaluaciones</a>
                <a href="/rh/orgchart" class="nav-item text-xs py-1.5">Organigrama</a>
              </>}
            </div>
          </div>
        ))}
      </nav>

      <div class="absolute bottom-0 left-0 right-0 p-4 border-t border-gray-200 bg-white">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-full bg-primary-100 flex items-center justify-center text-primary-700 font-bold text-sm">A</div>
          <div class="flex-1 min-w-0">
            <div class="text-sm font-medium text-gray-900 truncate" id="user-name">Admin</div>
            <div class="text-xs text-gray-500 truncate">Administrador</div>
          </div>
          <button onclick="logout()" class="p-1.5 text-gray-400 hover:text-gray-600 rounded-lg hover:bg-gray-100">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
            </svg>
          </button>
        </div>
      </div>
    </aside>

    <!-- Main Content -->
    <div class="flex-1 ml-64 flex flex-col min-h-screen">
      <!-- Top Bar -->
      <header class="topbar px-6 py-3 flex items-center justify-between">
        <div class="flex items-center gap-4">
          <button onclick="toggleSidebar()" class="lg:hidden p-2 rounded-lg hover:bg-gray-100">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
          <div>
            <h1 class="text-lg font-semibold text-gray-900">{title}</h1>
            <p class="text-xs text-gray-500">{activeModule.toUpperCase()} / {activePage}</p>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <div class="search-bar">
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <input type="text" placeholder="Busqueda global... (Ctrl+K)" class="search-input" id="global-search" />
          </div>
          <button class="relative p-2 rounded-lg hover:bg-gray-100" id="notif-btn">
            <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
            </svg>
            <span class="absolute top-1 right-1 w-2 h-2 bg-red-500 rounded-full" id="notif-dot"></span>
          </button>
        </div>
      </header>

      <!-- Page Content -->
      <main class="flex-1 p-6 overflow-auto">
        <slot />
      </main>
    </div>
  </div>

  <!-- Notifications Panel -->
  <div id="notif-panel" class="hidden fixed top-16 right-4 w-96 bg-white rounded-xl shadow-2xl border border-gray-200 z-50 max-h-96 overflow-y-auto">
    <div class="p-4 border-b border-gray-100 flex items-center justify-between">
      <span class="font-semibold text-gray-900">Notificaciones</span>
      <button onclick="markAllRead()" class="text-xs text-primary-600 hover:text-primary-700">Marcar todas leidas</button>
    </div>
    <div id="notif-list" class="divide-y divide-gray-50"></div>
  </div>

  <!-- Modal Container -->
  <div id="modal-container"></div>

  <script define:vars={{ API_URL }}>
    window.API_URL = API_URL;
    window.graphql = async (query, variables = {}) => {
      const res = await fetch(API_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ query, variables }),
      });
      const json = await res.json();
      if (json.errors) {
        console.error('GraphQL Error:', json.errors);
        throw new Error(json.errors[0].message);
      }
      return json.data;
    };

    window.toggleModule = (id) => {
      const sub = document.getElementById('submenu-' + id);
      const arrow = document.getElementById('arrow-' + id);
      if (sub.classList.contains('hidden')) {
        sub.classList.remove('hidden');
        arrow.classList.add('rotate-90');
      } else {
        sub.classList.add('hidden');
        arrow.classList.remove('rotate-90');
      }
    };

    window.toggleSidebar = () => {
      const sidebar = document.getElementById('sidebar');
      sidebar.classList.toggle('-translate-x-full');
    };

    window.logout = () => {
      localStorage.removeItem('fototec_token');
      localStorage.removeItem('fototec_user');
      window.location.href = '/';
    };

    document.addEventListener('keydown', (e) => {
      if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
        e.preventDefault();
        document.getElementById('global-search')?.focus();
      }
    });

    // Auto-open active module
    const activeModule = document.querySelector('[data-module]');
    if (activeModule) toggleModule(activeModule.dataset.module);

    // Notification panel toggle
    document.getElementById('notif-btn')?.addEventListener('click', () => {
      document.getElementById('notif-panel').classList.toggle('hidden');
    });
  </script>
</body>
</html>
