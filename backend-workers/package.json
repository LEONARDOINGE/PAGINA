{
  "name": "fototec-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute fototec-db --local --file=src/db/schema.sql",
    "db:seed": "wrangler d1 execute fototec-db --local --file=src/db/seed.sql",
    "db:seed:remote": "wrangler d1 execute fototec-db --remote --file=src/db/seed.sql",
    "typecheck": "wrangler types"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "hono": "^4.6.0",
    "graphql": "^16.9.0",
    "graphql-tag": "^2.12.6",
    "bcryptjs": "^2.4.3",
    "nanoid": "^5.0.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "wrangler": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
